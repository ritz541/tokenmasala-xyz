# GitHub OAuth app (Settings -> Developer settings -> OAuth Apps).
# An OAuth App has a single callback URL, so create two apps:
#   tokenmaxxing-dev -> http://api.tokenmaxxing.localhost:8788/auth/github/callback
#   tokenmaxxing     -> https://api.tokenmaxxing.851.sh/auth/github/callback
# Put the dev pair here for `bun run dev`; use the prod pair when deploying.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
